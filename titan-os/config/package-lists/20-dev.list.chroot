# TitanOS — DEV mode packages ("coding, proofing, testing").
# The important apps a programmer actually needs, kept lean for 2 GB RAM.

# --- core toolchain ---
build-essential
git
make
pkg-config

# --- languages / runtimes ---
python3
python3-pip
python3-venv
nodejs
npm

# --- editors (terminal editors are far lighter than an IDE on 2 GB) ---
neovim
vim
nano

# --- debug / test / lint ---
gdb
valgrind
shellcheck

# --- containers (opt-in: heavy on 2 GB, only started in dev mode) ---
docker.io
