# Backups
*.bak
*.orig
*~

# Simulation artifacts
*.vvp
*.vcd
*.fst
*.lxt
*.lxt2
a.out

# Logs (any path)
*.log

# Synthesis reports (regenerated by CI)
synthesis_*.txt
syn_*.txt
yosys_run.log
fpga_synthesis_report.json
ppa_results.json

# Generated synthesis netlists and FPGA build outputs (regenerated by
# fpga/synth_fpga_top.ys, syn/scripts/*, fpga/vivado_build.tcl)
syn/fpga_top_synth.v
syn/fpga_top_synth.json
syn/titan_x5b_synth.v
fpga/synth_netlist.v
fpga/build/
syn/reports/blocks/round2_progress.txt

# OpenLane run directories (hundreds of MB; final GDS/metrics are copied
# to openlane/<design>/final/ for archiving instead)
openlane/*/runs/

# Sim dumps
fb_dump.txt
sim_output.txt
test_output.txt
rtl_files.txt
*.bin

# Bundled tools / tarballs (NEVER commit)
gtkwave_ext/
gtkwave.zip
workspace-*
*.zip
*.tar
*.tar.gz

# Root-level images/PDFs (keep docs/assets/ only)
/*.png
/*.pdf

# Editor / AI tool artifacts
*.metadata.json
worklog.md

# Dev scratch
scratch/

# Python
__pycache__/
*.pyc
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
.vscode/
*.swp

# cocotb regression outputs (regenerated by tb/run_regression.py)
tb/uvm/*_results.xml

# Local MCP server config (machine-specific, holds key placeholders)
claude.json

# functional-coverage reports (regenerated by tb/run_regression.py)
tb/uvm/*_coverage.yml

# Node.js
node_modules/
